# SCP Environment Variables Example
# Copy this to .env and modify values as needed

# Core SCP Settings
SCP_NODE_ID=my_scp_node
SCP_API_KEY=your_secure_api_key_here
SCP_SECRET_KEY=your_encryption_secret_key_here
SCP_JWT_SECRET=your_jwt_signing_secret_here

# Server Settings
SCP_HOST=localhost
SCP_PORT=8765
SCP_MAX_CONNECTIONS=100

# Client Settings
SCP_SERVER_URL=ws://localhost:8765
SCP_TIMEOUT=30
SCP_MAX_RETRIES=3

# AI Integration
SCP_OLLAMA_URL=http://localhost:11434
SCP_DEFAULT_MODEL=tinyllama:latest

# Security
SCP_MAX_MESSAGE_SIZE=1048576
SCP_TOKEN_EXPIRY=3600

# Logging
SCP_LOG_LEVEL=INFO
SCP_LOG_FILE=/var/log/scp.log