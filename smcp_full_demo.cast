[0.013015, "o", "\r\n\u001b[96m\u001b[1m╔══════════════════════════════════════════════════════════╗\r\n║         SMCP - Secure Model Context Protocol            ║\r\n║          Multi-Agent Coordination Demo                  ║\r\n╚══════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n\u001b[93mSystem Architecture:\u001b[0m\r\n\r\n    ┌─────────────────────────────────────────┐\r\n    │            User Request                 │\r\n    │        \"Generate AI Report\"             │\r\n    └────────────────┬────────────────────────┘\r\n                     │\r\n         ┌───────────▼───────────┐\r\n         │   SMCP Orchestrator   │\r\n         │   [Security: JWT]     │\r\n         └───────────┬───────────┘\r\n                     │\r\n      ┌──────────────┼──────────────┐\r\n      ▼              ▼              ▼\r\n ┌─────────┐   ┌─────────┐   ┌─────────┐\r\n │Research │   │Analysis │   │ Writer  │\r\n │ Agent   │   │ Agent   │   │ Agent   │\r\n └─────────┘   └─────────┘   └─────────┘\r\n    \r\n"]
